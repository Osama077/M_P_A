# Git LFS — Large file tracking for Hugging Face Spaces deployment

# Parquet data files
data/*.parquet filter=lfs diff=lfs merge=lfs -text

# Model files
models/*.pkl filter=lfs diff=lfs merge=lfs -text
models/*.joblib filter=lfs diff=lfs merge=lfs -text
models/*.txt filter=lfs diff=lfs merge=lfs -text
models/*.json filter=lfs diff=lfs merge=lfs -text

# Visualization cache (if any)
visualizations/__pycache__/** filter=lfs diff=lfs merge=lfs -text
